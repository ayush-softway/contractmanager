# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# Where the browser-facing web app runs (for CORS + OAuth redirect back)
WEB_ORIGIN=http://localhost:3000

# SQLite DB path (created automatically on first boot)
DATABASE_URL=file:./data/contract-generator.db

# Session cookie secret (generate with: openssl rand -hex 32)
SESSION_SECRET=replace_me_with_random_hex

# ---------------------------------------------------------------------------
# Google Cloud (see docs/GOOGLE_CLOUD_SETUP.md)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must exactly match the Authorized Redirect URI in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ---------------------------------------------------------------------------
# Anthropic (Claude) — for AI intake, review chat, and legal analysis
# Get a key at https://console.anthropic.com
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Web app (exposed to the browser — must be NEXT_PUBLIC_*)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Add-on (HTTP-backed Workspace Add-on)
# ---------------------------------------------------------------------------
ADDON_PORT=4100
# The public HTTPS URL your add-on manifest points to. For local dev use ngrok.
ADDON_PUBLIC_URL=https://your-ngrok-subdomain.ngrok-free.app
